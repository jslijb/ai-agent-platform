# Docker Compose 环境变量模板
# 本地开发：大部分使用默认值即可，仅需配置 MODEL_BASE_PATH
# 服务器部署：复制为 .env 并填写实际值

# 模型文件基础路径（本地 Windows / 服务器 Linux）
MODEL_BASE_PATH=D:\models\modelscope\models

# PostgreSQL
PG_PORT=5432
PG_USER=aiagent
PG_PASSWORD=aiagent_secret
PG_DB=agentdb

# Redis
REDIS_PORT=6379

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=test1234

# 服务端口
EMBEDDING_PORT=8011
EMBEDDING_THREADS=4
RERANKER_PORT=8010
RERANKER_THREADS=4
DATA_SERVICE_PORT=8001
NEXTJS_PORT=3000
NGINX_PORT=80

# PaddleOCR（仅服务器）
PADDLEOCR_PORT=8020
PADDLEOCR_IMAGE=paddlepaddle/paddleocr:latest-gpu
