# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_ADMIN_USER=your_admin_user
PG_ADMIN_PASSWORD=your_admin_password
PG_ADMIN_DB=your_admin_db
PG_USER=your_app_user
PG_PASSWORD=your_app_password
PG_DB=agentdb
DATABASE_URL=postgresql://your_app_user:your_app_password@localhost:5432/agentdb

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth v5
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
